# BJTMaster API — copy to .env.local and fill in values
PORT=3001

# JWT
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-strong-random-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database (Prisma — set up in later sprint)
DATABASE_URL=postgresql://bjt:bjt_pass@localhost:5432/bjt_dev
