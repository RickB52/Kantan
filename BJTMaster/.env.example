# BJT Master — Environment Variables Example
# Copy file này thành .env.local và điền giá trị thật
# KHÔNG commit .env.local vào git

# ── Database (local Docker) ─────────────────────────────
DATABASE_URL=postgresql://bjt_user:bjt_local_pass@localhost:5432/bjt_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bjt_dev
DB_USER=bjt_user
DB_PASS=bjt_local_pass

# ── Redis (local Docker) ────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Storage (MinIO local — thay S3) ────────────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=bjt_minio_user
STORAGE_SECRET_KEY=bjt_minio_pass
STORAGE_BUCKET_AUDIO=bjt-audio
STORAGE_BUCKET_IMAGES=bjt-images
STORAGE_PUBLIC_URL=http://localhost:9000

# ── Email (Mailhog local — thay SES) ───────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@bjt.local

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=change_this_to_random_64char_string_in_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=another_random_64char_string
REFRESH_TOKEN_EXPIRES_IN=30d

# ── OAuth (để trống nếu chưa setup) ────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ── AI Tutor (để trống — dùng mock response khi dev) ───
# Điền sau khi hoàn thiện app mobile
ANTHROPIC_API_KEY=
AI_MOCK_MODE=true        # true = dùng response giả, không gọi API thật

# ── Payment (để trống — integrate sau khi launch) ──────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
IOS_IAP_SHARED_SECRET=
ANDROID_SERVICE_ACCOUNT_JSON=

# ── App ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:8081,http://localhost:3001

# ── Monitoring (free tiers — optional khi dev) ─────────
SENTRY_DSN=      # Sentry free: 5K errors/month
